{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base"
    ],
    "semanticCommits": "enabled",
    "rangeStrategy": "bump",
    "packageRules": [
        {
            "matchUpdateTypes": [
                "major"
            ],
            "enabled": false
        }
    ]
}